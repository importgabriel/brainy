# ── Supabase ──────────────────────────────────────────────────
# Dashboard → Project Settings → General → Reference ID
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Dashboard → Project Settings → API → Secret key (sb_secret_...)
# Used server-side only — never expose to client
SUPABASE_SECRET_KEY=sb_secret_YOUR_SECRET_KEY

# Dashboard → Project Settings → API → Publishable key (sb_publishable_...)
# Safe for client-side use
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Dashboard → Project Settings → General → Reference ID (just the ID, not full URL)
MCP_USE_OAUTH_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# ── OpenAI ────────────────────────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=your_openai_api_key

# ── Dev bypass (LOCAL ONLY — remove before deploying) ─────────
# Any string — used as userId when OAuth is skipped locally
# MCP_DEV_USER_ID=test-user-local

# ── Server ────────────────────────────────────────────────────
MCP_URL=http://localhost:3000
